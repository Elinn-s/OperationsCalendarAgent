# App
APP_BASE_URL=http://localhost:8000
APP_DATABASE_MODE=sqlite
DATABASE_URL=

# Initial login account
AUTH_ENABLED=false
APP_ADMIN_EMAIL=admin@example.com
APP_ADMIN_PASSWORD=change-me-before-sharing
AUTH_SESSION_SECONDS=86400
AUTH_COOKIE_SECURE=false

# Dify PDF extraction
DIFY_API_KEY=
DIFY_BASE_URL=https://api.dify.ai/v1
DIFY_WORKFLOW_ID=

# Local OCR Plan B
ENABLE_LOCAL_OCR=false

# SMTP fallback account
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
SMTP_STARTTLS=true
SMTP_SSL=false

# Reminder rules
REMINDER_DAYS=7
PLAN_REMINDER_DAYS=7
ESCALATION_EMAILS=
